{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the ICEPAB Nexus",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "gpa": { "type": "number" },
        "aroScore": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "gpa", "aroScore"]
    },
    "Broadcast": {
      "title": "Broadcast",
      "description": "A live push notification from the admin",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "authorId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "authorId", "timestamp"]
    },
    "PendingQuestion": {
      "title": "Pending Question",
      "description": "A question uploaded by a user pending validation",
      "type": "object",
      "properties": {
        "courseCode": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "authorId": { "type": "string" },
        "votes": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["courseCode", "question", "options", "correctAnswer", "authorId", "votes", "status"]
    },
    "HostedTest": {
      "title": "Hosted Test",
      "description": "A CBT test hosted by a verified user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "courseCode": { "type": "string" },
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "questions": { "type": "array" },
        "createdAt": { "type": "number" },
        "expiresAt": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "ended"] }
      },
      "required": ["id", "title", "courseCode", "hostId", "hostName", "questions", "createdAt", "expiresAt", "status"]
    },
    "TestResult": {
      "title": "Test Result",
      "description": "A user's result for a hosted test",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "timestamp": { "type": "number" }
      },
      "required": ["testId", "userId", "userName", "score", "totalQuestions", "timestamp"]
    },
    "Resource": {
      "title": "Resource",
      "description": "A study resource in the vault",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["PDF", "Link"] },
        "url": { "type": "string" },
        "course": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "url", "course", "uploadedBy", "userId"]
    },
    "CommunityReview": {
      "title": "Community Review",
      "description": "A user review or feedback",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "rating"]
    },
    "Whisper": {
      "title": "Whisper",
      "description": "An anonymous or semi-anonymous message in the community feed",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "authorUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "author", "authorUid"]
    },
    "FlexStoreListing": {
      "title": "Flex Store Listing",
      "description": "A product or service listed in the campus marketplace",
      "type": "object",
      "properties": {
        "itemName": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "whatsappNumber": { "type": "string" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" },
        "vendorName": { "type": "string" },
        "vendorUid": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["itemName", "category", "price", "whatsappNumber", "location", "imageUrl", "vendorName", "vendorUid", "createdAt"]
    },
    "PaymentVerification": {
      "title": "Payment Verification",
      "description": "A request for student verification via payment reference",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "reference": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "userName", "reference", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/broadcasts/{broadcastId}": {
      "schema": { "$ref": "#/entities/Broadcast" },
      "description": "Stores live broadcasts"
    },
    "/pending_questions/{questionId}": {
      "schema": { "$ref": "#/entities/PendingQuestion" },
      "description": "Stores pending questions for validation"
    },
    "/hosted_tests/{testId}": {
      "schema": { "$ref": "#/entities/HostedTest" },
      "description": "Stores hosted tests"
    },
    "/test_results/{resultId}": {
      "schema": { "$ref": "#/entities/TestResult" },
      "description": "Stores results for hosted tests"
    },
    "/resources/{resourceId}": {
      "schema": { "$ref": "#/entities/Resource" },
      "description": "Stores study resources"
    },
    "/community_reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/CommunityReview" },
      "description": "Stores community reviews"
    },
    "/whispers/{whisperId}": {
      "schema": { "$ref": "#/entities/Whisper" },
      "description": "Stores community whispers"
    },
    "/flex_store_listings/{listingId}": {
      "schema": { "$ref": "#/entities/FlexStoreListing" },
      "description": "Stores campus marketplace listings"
    },
    "/payment_verifications/{verificationId}": {
      "schema": { "$ref": "#/entities/PaymentVerification" },
      "description": "Stores student payment verification requests"
    }
  }
}
